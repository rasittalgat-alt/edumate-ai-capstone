# EduMate environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# n8n webhook URL (update to your own instance if self-hosting)
N8N_WEBHOOK_URL=https://n8n.sheshimai.cloud/webhook/edumate-ai

# Google Gemini API key (used for embedding + LLM)
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone vector database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_HOST=https://your-index.svc.aped-4627-b74a.pinecone.io

# Google Sheets (for Progress Agent)
# Set the spreadsheet ID from your Google Sheets URL
SPREADSHEET_ID=your_google_sheets_document_id

# Brave Search API (for MCP integration in Tutor Agent)
# Get free key at: https://brave.com/search/api/
# Run MCP server: pm2 start supergateway --name mcp-brave -- --port 3100 --stdio "npx -y @modelcontextprotocol/server-brave-search" --outputTransport streamableHttp --cors
BRAVE_API_KEY=your_brave_search_api_key_here
